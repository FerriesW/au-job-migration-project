au_jobs_radar:
  target: dev
  outputs:
    dev:
      type: bigquery
      method: service-account
      project:  "{{ env_var('GCP_PROJECT_ID') }}"
      dataset:  staging
      keyfile:  "{{ env_var('GOOGLE_APPLICATION_CREDENTIALS') }}"
      location: "{{ env_var('GCP_LOCATION', 'australia-southeast1') }}"
      threads: 4
      timeout_seconds: 300
      priority: interactive
      job_retries: 1
      job_creation_timeout_seconds: 60

    prod:
      type: bigquery
      method: service-account
      project:  "{{ env_var('GCP_PROJECT_ID') }}"
      dataset:  marts
      keyfile:  "{{ env_var('GOOGLE_APPLICATION_CREDENTIALS') }}"
      location: "{{ env_var('GCP_LOCATION', 'australia-southeast1') }}"
      threads: 4
      timeout_seconds: 300
      priority: batch
      job_retries: 2
