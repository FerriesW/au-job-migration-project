# ============================================================
# AU Migration & Jobs Radar — Environment Variables Template
# ============================================================
# Copy this file to `.env` and fill in actual values.
# `.env` is gitignored — never commit real secrets.
# ============================================================

# --- Adzuna API (https://developer.adzuna.com/) ---
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here
ADZUNA_COUNTRY=au

# --- Google Cloud Platform ---
# Path to service account JSON key (absolute or relative to project root)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json
GCP_PROJECT_ID=au-jobs-radar
GCP_LOCATION=australia-southeast2
GCS_BUCKET_RAW=au-jobs-radar-raw

# BigQuery datasets
BQ_DATASET_RAW=raw
BQ_DATASET_STAGING=staging
BQ_DATASET_MARTS=marts

# --- Alibaba DashScope (Qwen) ---
DASHSCOPE_API_KEY=your_dashscope_key_here
QWEN_MODEL=qwen-turbo

# --- Pipeline runtime ---
LOG_LEVEL=INFO
SAMPLE_LIMIT=0  # 0 = no limit; set to e.g. 100 for dry runs
