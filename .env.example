# ============================================================
# AU Migration & Jobs Radar — Environment Variables Template
# ============================================================
# Copy this file to `.env` and fill in actual values.
# `.env` is gitignored — never commit real secrets.
# ============================================================

# Adzuna
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=au

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json
GCP_PROJECT_ID=au-jobs-radar
GCP_LOCATION=australia-southeast1
GCS_BUCKET_RAW=au-jobs-radar-raw
BQ_DATASET_RAW=raw
BQ_DATASET_STAGING=staging
BQ_DATASET_MARTS=marts

# Alibaba DashScope (Qwen)
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-turbo
JUDGE_MODEL=qwen-plus
# Endpoint override. Mainland China default is used when unset:
#   https://dashscope.aliyuncs.com/compatible-mode/v1
# International (Singapore) tenants with free-tier credits should use:
#   https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=

# Runtime
LOG_LEVEL=INFO
SAMPLE_LIMIT=0
